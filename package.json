{
  "name": "school-management-system",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10",
  "engines": {
    "node": "18.x || 20.x",
    "npm": "10.x"
  },
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "install:all": "npm install",
    "build": "npm run build --workspace=school-management-client",
    "vercel-build": "npm run build --workspace=school-management-client",
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "seed": "npm run seed --prefix server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
